# Deterministic line endings across platforms (silences the LF/CRLF warning on Windows).
* text=auto eol=lf

# Windows-native scripts keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binary — never normalize
*.png binary
*.jpg binary
*.webp binary
*.ico binary
*.zip binary
*.tgz binary
*.gz binary
