# Project Starfish — example environment. Copy to `.env` and fill in. NEVER commit your real .env.
# NOTE: model provider API keys (Anthropic/OpenAI/Google/OpenRouter) are NOT stored here — Starfish
# keeps them in the OS keychain (Electron safeStorage). .env is for build tooling + optional flags only.

# --- Art pipeline (only needed if you regenerate the Fleet portraits via `npm run art:fleet`) ---
ATLASCLOUD_API_KEY=your-atlascloud-key-here

# --- Optional governance/runtime flags (operator-set; do NOT rely on .env for these in production) ---
# Hosted-router (OpenRouter) data-egress opt-in. Off unless explicitly enabled.
# STARFISH_ALLOW_EGRESS=0
# Override the governed project root (advanced).
# STARFISH_PROJECT_ROOT=
# Path to the default skills pack to govern on first run.
# STARFISH_SKILLS_PACK=
