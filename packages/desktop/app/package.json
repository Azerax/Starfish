{
  "name": "@starfish/desktop-app",
  "private": true,
  "version": "0.2.0",
  "description": "Project Starfish \u2014 governed desktop (ring 3) Electron shell.",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dev:web": "vite --config vite.web.config.ts",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "init:gov": "node init-governance.mjs",
    "sync:art": "node sync-art.mjs",
    "build:app": "electron-vite build",
    "pack": "electron-vite build && npx --yes electron-builder --dir",
    "dist": "electron-vite build && npx --yes electron-builder"
  },
  "dependencies": {
    "@starfish/governance-core": "file:../../governance-core",
    "@starfish/governance-hooks": "file:../../governance-hooks",
    "@starfish/desktop": "file:..",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@starfish/governance-overlay": "file:../../governance-overlay"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.2.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  }
}